---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---
<section class="bg-white border-y border-slate-200 overflow-hidden">
  <div class="container-x py-10 sm:py-14">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <div class="flex items-center gap-6 reveal">
        <div class="shrink-0 grid place-items-center w-14 h-14 rounded-full bg-ink text-white font-display italic text-xl">
          JR
        </div>
        <div>
          <p class="text-sm text-slate-500">Atendido personalmente por</p>
          <p class="display-sm italic-display text-ink !font-light mt-0.5">{site.owner.name}</p>
          <p class="text-xs uppercase tracking-[0.18em] text-slate-500 mt-1">{site.owner.role} · {site.shortName}</p>
        </div>
      </div>
      <div class="flex items-center gap-8 text-sm text-slate-600 reveal">
        <div class="flex items-center gap-2">
          <Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-700" />
          Sin intermediarios
        </div>
        <div class="flex items-center gap-2">
          <Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-700" />
          Trato directo
        </div>
        <div class="flex items-center gap-2">
          <Icon name="lucide:check-circle-2" class="w-4 h-4 text-brand-700" />
          Respuesta en el día
        </div>
      </div>
    </div>
  </div>
</section>
