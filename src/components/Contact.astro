---
import { Icon } from 'astro-icon/components';
import { site, waLink, telLink } from '../data/site';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID;
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : '#form-not-configured';
---
<section id="contacto" class="section relative overflow-hidden text-white mesh-dark grain">
  <div class="container-x relative z-10">
    <div class="grid lg:grid-cols-12 gap-14 items-start">
      <div class="lg:col-span-7 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/50">— Contacto</span>
          <span class="h-px flex-1 max-w-24 bg-white/20"></span>
        </div>
        <h2 class="display-xl text-white" data-split="words">
          ¿Tenés una
          <span class="italic-display text-accent-400">pérdida</span>?
        </h2>
        <p class="mt-8 text-xl text-white/70 max-w-xl font-light leading-relaxed">
          Escribinos con una foto o video del problema. Te respondemos con presupuesto aproximado o coordinamos visita sin cargo.
        </p>

        <div class="mt-12 flex flex-wrap gap-3">
          <a href={waLink({ source: 'contact-section' })} class="btn-whatsapp btn-arrow" target="_blank" rel="noopener" data-magnetic="0.3" data-track="cta:contact-section:whatsapp">
            <Icon name="lucide:message-circle" class="w-[18px] h-[18px]" />
            Abrir WhatsApp
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
          <a href={telLink} class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-[13px] font-semibold border border-white/20 text-white hover:bg-white hover:text-ink transition">
            <Icon name="lucide:phone" class="w-4 h-4" />
            {site.contact.phoneDisplay}
          </a>
        </div>

        <div class="mt-16 grid grid-cols-2 gap-8 max-w-lg">
          <div class="border-t border-white/15 pt-5">
            <p class="text-[10px] uppercase tracking-[0.18em] text-white/50">Horario</p>
            <p class="mt-2 text-sm text-white/90">Lun a Sáb · 8 a 20 hs</p>
            <p class="text-sm text-accent-400">Urgencias 24/7</p>
          </div>
          <div class="border-t border-white/15 pt-5">
            <p class="text-[10px] uppercase tracking-[0.18em] text-white/50">Correo</p>
            <a href={`mailto:${site.contact.email}`} class="mt-2 block text-sm text-white/90 hover:text-accent-400 break-all">{site.contact.email}</a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 reveal">
        <div class="rounded-[28px] bg-white text-slate-800 p-8 sm:p-10 relative shadow-2xl">
          <div aria-hidden="true" class="absolute -top-1 left-10 right-10 h-1 bg-white/50 rounded-full blur-sm"></div>
          <div class="flex items-center justify-between">
            <div>
              <h3 class="display-sm text-ink !font-medium">Agendar visita</h3>
              <p class="text-sm text-slate-500 mt-1">Respuesta en el día hábil.</p>
            </div>
            <span class="grid place-items-center w-12 h-12 rounded-2xl bg-ink text-white">
              <Icon name="lucide:mail" class="w-5 h-5" stroke-width="1.5" />
            </span>
          </div>

          <form
            action={formAction}
            method="POST"
            enctype="multipart/form-data"
            class="mt-8 space-y-5"
            data-contact-form
            data-form-configured={formspreeId ? 'true' : 'false'}
            novalidate
          >
            <input type="hidden" name="_next" value={`${site.url}/gracias`} />
            <label class="block">
              <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Nombre</span>
              <input name="name" required autocomplete="name" class="mt-1.5 block w-full border-0 border-b border-slate-300 bg-transparent px-0 py-2.5 text-base focus:border-ink focus:ring-0 outline-none transition placeholder:text-slate-400" placeholder="Tu nombre" />
            </label>
            <div class="grid grid-cols-2 gap-5">
              <label class="block">
                <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Teléfono</span>
                <input name="phone" type="tel" required autocomplete="tel" inputmode="tel" pattern="^(\+?54)?\s?(9)?\s?\(?\d{2,4}\)?[\s-]?\d{3,4}[\s-]?\d{4}$" title="Ej: 11 1234-5678 o +54 9 11 1234 5678" class="mt-1.5 block w-full border-0 border-b border-slate-300 bg-transparent px-0 py-2.5 text-base focus:border-ink focus:ring-0 outline-none transition placeholder:text-slate-400 invalid:[&:not(:placeholder-shown)]:border-red-400" placeholder="11 1234-5678" />
              </label>
              <label class="block">
                <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Zona</span>
                <input name="area" autocomplete="address-level2" class="mt-1.5 block w-full border-0 border-b border-slate-300 bg-transparent px-0 py-2.5 text-base focus:border-ink focus:ring-0 outline-none transition placeholder:text-slate-400" placeholder="Martínez" />
              </label>
            </div>
            <label class="block">
              <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Contanos el problema</span>
              <textarea name="message" rows="3" required class="mt-1.5 block w-full border-0 border-b border-slate-300 bg-transparent px-0 py-2.5 text-base focus:border-ink focus:ring-0 outline-none transition placeholder:text-slate-400 resize-none" placeholder="¿Qué está pasando?"></textarea>
            </label>
            <label class="block">
              <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Foto o video <span class="text-slate-400 normal-case tracking-normal">(opcional, hasta 10 MB)</span></span>
              <input
                type="file"
                name="attachment"
                accept="image/*,video/*"
                class="mt-1.5 block w-full text-[13px] text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-slate-100 file:px-4 file:py-2 file:text-[12px] file:font-semibold file:text-ink hover:file:bg-slate-200 file:cursor-pointer cursor-pointer"
              />
            </label>

            <div class="hidden" aria-hidden="true">
              <label>No completar este campo <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
            </div>

            <label class="flex items-start gap-3 text-[12px] text-slate-600 leading-relaxed cursor-pointer">
              <input type="checkbox" name="consent" required class="mt-0.5 w-4 h-4 rounded border-slate-300 text-ink focus:ring-ink" />
              <span>
                Autorizo a {site.shortName} a contactarme por los medios que dejé.
                Ver <a href="/privacidad" class="underline hover:text-ink">política de privacidad</a>.
              </span>
            </label>

            <button type="submit" class="btn-dark w-full mt-4">
              <Icon name="lucide:send" class="w-4 h-4" />
              Enviar consulta
            </button>
            <p aria-live="polite" data-form-status class="text-[13px] text-center min-h-[1.2em]"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
