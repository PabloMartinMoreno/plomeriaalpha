---
import { Icon } from 'astro-icon/components';

const faqs = [
  { q: '¿Cobran por el presupuesto o la visita?', a: 'No. El diagnóstico y presupuesto son sin cargo. Solo cobramos cuando aprobás el trabajo.' },
  { q: '¿Cuánto tardan en llegar?', a: 'Para urgencias en Zona Norte, el objetivo es menos de 2 horas. Para trabajos coordinados, agendamos día y horario fijo.' },
  { q: '¿Hacen trabajos de gas?', a: 'Sí. Plomero matriculado con pruebas de hermeticidad aprobadas. Firmamos trámites ante la distribuidora.' },
  { q: '¿Qué formas de pago aceptan?', a: 'Efectivo, transferencia, MercadoPago, débito y Cuenta DNI. Emitimos factura A o B según corresponda.' },
  { q: '¿Los trabajos tienen garantía?', a: 'Sí, todos los trabajos incluyen garantía escrita sobre mano de obra y materiales.' },
  { q: '¿Atienden fines de semana?', a: 'Sábados en horario normal; domingos solo urgencias. Las urgencias tienen un adicional razonable.' },
  { q: '¿Usan marcas reconocidas?', a: 'Sí. Trabajamos con Ferrum, FV, Peisa, Saladillo, Acqua System y otras marcas líderes con repuestos disponibles.' },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<section class="section bg-slate-50 relative">
  <div class="container-narrow">
    <div class="grid md:grid-cols-12 gap-10 mb-16">
      <div class="md:col-span-6 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Preguntas frecuentes</span>
        </div>
        <h2 class="display-lg" data-split="words">
          Dudas
          <span class="italic-display text-brand-700">habituales</span>.
        </h2>
      </div>
      <div class="md:col-span-6 reveal flex items-center">
        <p class="text-lg text-slate-600 leading-relaxed">
          Las consultas que más nos hacen antes de contratarnos. Si tu pregunta no está acá, escribinos por WhatsApp.
        </p>
      </div>
    </div>

    <div class="space-y-2">
      {faqs.map((item, i) => (
        <details class="reveal group rounded-2xl bg-white border border-slate-200 open:border-ink open:shadow-xl open:shadow-ink/5 transition-all duration-500 overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-6 list-none px-7 py-6">
            <div class="flex items-center gap-6">
              <span class="font-mono text-xs text-slate-500 group-open:text-brand-600 transition-colors">{String(i+1).padStart(2,'0')}</span>
              <h3 class="text-lg sm:text-xl font-display text-ink">{item.q}</h3>
            </div>
            <span class="shrink-0 relative w-5 h-5">
              <span class="absolute inset-x-0 top-1/2 h-[2px] -translate-y-1/2 bg-ink"></span>
              <span class="absolute inset-y-0 left-1/2 w-[2px] -translate-x-1/2 bg-ink transition-transform duration-500 group-open:rotate-90 group-open:scale-0"></span>
            </span>
          </summary>
          <div class="px-7 pb-7 pl-[5rem]">
            <p class="text-slate-600 leading-relaxed text-[15px]">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
