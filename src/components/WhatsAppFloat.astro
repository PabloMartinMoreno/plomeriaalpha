---
import { Icon } from 'astro-icon/components';
import { waLink } from '../data/site';
---
<a
  href={waLink()}
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
  class="fixed bottom-5 right-5 z-50 group flex items-center gap-3 rounded-full bg-accent-600 hover:bg-accent-700 text-white pl-4 pr-5 py-3 shadow-2xl shadow-accent-900/30 transition-all motion-safe:hover:scale-105"
>
  <span class="relative grid place-items-center w-8 h-8">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white/30"></span>
    <Icon name="lucide:message-circle" class="relative w-6 h-6" />
  </span>
  <span class="font-semibold text-sm hidden sm:inline">WhatsApp</span>
</a>
