---
import { Icon } from 'astro-icon/components';
import { waLink } from '../data/site';
---
<a
  href={waLink({ source: 'float' })}
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
  data-track="cta:float:whatsapp"
  class="fixed bottom-5 right-5 z-50 group hidden md:flex items-center gap-3 rounded-full bg-success-600 hover:bg-success-700 text-white pl-4 pr-5 py-3 shadow-2xl shadow-success-900/40 transition-all motion-safe:hover:scale-105 motion-safe:hover:-translate-y-0.5"
>
  <span class="relative grid place-items-center w-7 h-7">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white/40"></span>
    <Icon name="lucide:message-circle" class="relative w-6 h-6" />
  </span>
  <span class="font-semibold text-sm hidden sm:inline">Chat</span>
</a>
