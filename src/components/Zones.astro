---
import { Icon } from 'astro-icon/components';
import { site, waLink, zones } from '../data/site';
---
<section id="zonas" class="section bg-slate-50 relative overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 opacity-50 pointer-events-none">
    <svg class="absolute inset-0 w-full h-full text-slate-300/40" aria-hidden="true">
      <defs>
        <pattern id="dots" width="28" height="28" patternUnits="userSpaceOnUse">
          <circle cx="1.2" cy="1.2" r="1.2" fill="currentColor"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)"/>
    </svg>
  </div>

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-28 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Cobertura</span>
          <span class="h-px flex-1 max-w-24 bg-slate-300"></span>
        </div>
        <h2 class="display-lg" data-split="words">
          Zona Norte del
          <span class="italic-display text-brand-700">GBA</span>.
        </h2>
        <p class="mt-8 text-lg text-slate-600 max-w-md leading-relaxed">
          Operamos de lunes a sábado en toda la zona norte del conurbano. Urgencias también domingos.
        </p>

        <a href={waLink({ notes: '¿llegan hasta mi zona?', source: 'zones-ask' })} class="mt-8 inline-flex items-center gap-2 text-ink font-semibold border-b-2 border-ink pb-0.5 hover:gap-3 transition-all" target="_blank" rel="noopener" data-track="cta:zones-ask:whatsapp">
          ¿Tu barrio no está en la lista? <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
        </a>
      </div>

      <div class="lg:col-span-7">
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2 reveal-stagger">
          {zones.map((z) => (
            <li>
              <a href={`/zonas/${z.slug}`} class="group relative flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-5 py-4 hover:border-ink hover:bg-ink hover:text-white transition-all duration-300">
                <span class="flex items-center gap-3">
                  <Icon name="lucide:map-pin" class="w-4 h-4 text-brand-600 group-hover:text-accent-400 transition-colors" stroke-width="1.5" />
                  <span class="text-sm font-medium">{z.name}</span>
                </span>
                <Icon name="lucide:arrow-up-right" class="w-4 h-4 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" />
              </a>
            </li>
          ))}
          <li class="col-span-2">
            <a
              href={waLink({ notes: 'Urgencia fuera de zona', source: 'zones-out-of-area' })}
              target="_blank"
              rel="noopener"
              class="group relative flex items-center justify-between gap-4 rounded-xl bg-ink text-white px-5 py-4 hover:bg-slate-900 transition-colors"
              data-track="cta:zones-out-of-area:whatsapp"
            >
              <span class="flex items-center gap-3">
                <Icon name="lucide:siren" class="w-4 h-4 text-accent-400 shrink-0" stroke-width="1.5" />
                <span class="flex flex-col leading-tight">
                  <span class="text-sm font-semibold">Urgencias fuera de zona</span>
                  <span class="text-[12px] text-white/70">CABA y primer cordón Oeste — consultanos</span>
                </span>
              </span>
              <Icon name="lucide:arrow-up-right" class="w-4 h-4 shrink-0 opacity-70 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" />
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
