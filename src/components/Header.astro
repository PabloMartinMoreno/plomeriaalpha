---
import { Icon } from 'astro-icon/components';
import { site, waLink, telLink } from '../data/site';

const nav = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#zonas', label: 'Zonas' },
  { href: '#por-que', label: 'Por qué elegirnos' },
  { href: '#contacto', label: 'Contacto' },
];
---
<header class="sticky top-0 z-40 w-full border-b border-slate-200/70 bg-white/80 backdrop-blur-md">
  <div class="container-x flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-bold text-slate-900" aria-label={site.shortName}>
      <span class="grid place-items-center w-9 h-9 rounded-lg bg-brand-600 text-white">
        <Icon name="lucide:wrench" class="w-5 h-5" />
      </span>
      <span class="hidden sm:inline">{site.owner.name}</span>
      <span class="hidden md:inline text-slate-400 font-normal">· Plomería</span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Principal">
      {nav.map((item) => (
        <a href={item.href} class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 hover:text-slate-900 transition">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={telLink} class="btn-ghost hidden sm:inline-flex text-sm" aria-label={`Llamar al ${site.contact.phoneDisplay}`}>
        <Icon name="lucide:phone" class="w-4 h-4" />
        <span class="hidden lg:inline">{site.contact.phoneDisplay}</span>
      </a>
      <a href={waLink()} class="btn-whatsapp text-sm px-4 py-2" target="_blank" rel="noopener">
        <Icon name="lucide:message-circle" class="w-4 h-4" />
        <span class="hidden sm:inline">WhatsApp</span>
      </a>
    </div>
  </div>
</header>
