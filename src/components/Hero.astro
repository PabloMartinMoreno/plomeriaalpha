---
import { Icon } from 'astro-icon/components';
import { site, waLink, telLink, licenseLabel, cta } from '../data/site';

const stats = [
  { n: '24/7', label: 'urgencias todo el año', icon: 'lucide:siren' },
  { n: '<2hs', label: 'objetivo de llegada en zona', icon: 'lucide:timer' },
  { n: '16', label: 'partidos de Zona Norte', icon: 'lucide:map-pin' },
  { n: 'A·B', label: 'factura según corresponda', icon: 'lucide:receipt' },
];
---
<section class="relative isolate min-h-[100svh] bg-white overflow-hidden" data-hero>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 mesh-bg"></div>
    <svg class="absolute inset-0 w-full h-full text-slate-900/[0.035]" aria-hidden="true">
      <defs>
        <pattern id="grid" width="72" height="72" patternUnits="userSpaceOnUse">
          <path d="M 72 0 L 0 0 0 72" fill="none" stroke="currentColor" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
    </svg>
    <div class="absolute -top-40 right-[-10%] w-[700px] h-[700px] rounded-full bg-brand-200/40 blur-3xl" data-parallax="0.3"></div>
    <div class="absolute bottom-0 left-[-10%] w-[600px] h-[600px] rounded-full bg-accent-300/20 blur-3xl" data-parallax="0.2"></div>
  </div>

  <div class="container-x pt-28 sm:pt-32 lg:pt-40 pb-20 lg:pb-28 relative">
    <div class="flex items-center gap-3 hero-line">
      <span class="eyebrow">
        <span class="ring-dot"></span>
        Disponible ahora
      </span>
      <span class="text-xs text-slate-500 hidden sm:inline">Zona Norte GBA · Urgencias 24/7</span>
    </div>

    <h1 class="mt-10 display-xl text-ink hero-line">
      <span class="block" data-split="words">Plomería de oficio,</span>
      <span class="block">
        <span class="italic-display text-brand-700" data-split="words">sin vueltas</span>,
        <span class="text-slate-500" data-split="words">en Zona Norte.</span>
      </span>
    </h1>

    <div class="mt-10 grid lg:grid-cols-12 gap-10 items-end">
      <div class="lg:col-span-6 xl:col-span-5 hero-side">
        <p class="text-xl sm:text-2xl text-slate-700 leading-[1.4] font-light max-w-xl">
          Soy <strong class="text-ink font-medium">{site.owner.name}</strong>, plomero matriculado al frente de <strong class="text-ink font-medium">{site.shortName}</strong>.
          Urgencias, fugas, gas y termotanques con presupuesto sin cargo y garantía escrita.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={waLink({ source: 'hero' })} class="btn-whatsapp btn-arrow" target="_blank" rel="noopener" data-magnetic="0.3" data-track="cta:hero:whatsapp">
            <Icon name="lucide:message-circle" class="w-[18px] h-[18px]" />
            {cta.primary}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
          <a href="#consulta-guiada" class="btn-outline" data-magnetic="0.25" data-track="cta:hero:wizard">
            <Icon name="lucide:sparkles" class="w-4 h-4" />
            {cta.consult}
          </a>
          <a href={telLink} class="btn-ghost hidden sm:inline-flex" data-track="cta:hero:phone">
            <Icon name="lucide:phone" class="w-4 h-4" />
            {site.contact.phoneDisplay}
          </a>
        </div>
      </div>

      <div class="lg:col-span-6 xl:col-span-7 lg:pl-10 hero-side">
        <div class="relative rounded-[32px] border border-slate-200 bg-white/70 backdrop-blur-sm p-8 sm:p-10 overflow-hidden">
          <svg class="absolute -right-6 -top-6 w-48 h-48 text-brand-600/10" viewBox="0 0 160 160" fill="none" aria-hidden="true">
            <circle cx="80" cy="80" r="72" stroke="currentColor" stroke-width="1" />
            <circle cx="80" cy="80" r="48" stroke="currentColor" stroke-width="1" />
            <circle cx="80" cy="80" r="24" stroke="currentColor" stroke-width="1" />
          </svg>

          <div class="relative flex items-start gap-6">
            <div class="shrink-0">
              <svg class="w-20 h-20" viewBox="0 0 80 80" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="hero-mon" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#1d4ed8" />
                    <stop offset="100%" stop-color="#0f172a" />
                  </linearGradient>
                </defs>
                <rect x="2" y="2" width="76" height="76" rx="20" fill="url(#hero-mon)" />
                <path d="M40 18 C30 30 22 40 22 48 a18 18 0 0 0 36 0 c0-8-8-18-18-30z" fill="white" opacity="0.95" />
                <circle cx="40" cy="50" r="4" fill="#1d4ed8" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[10px] uppercase tracking-[0.22em] font-semibold text-slate-500">Reconocimientos</p>
              <p class="mt-2 text-xl font-display text-ink leading-snug">Matrícula · Gas · Garantía · 24/7</p>
              <p class="mt-3 text-[13px] text-slate-600 leading-relaxed max-w-sm">
                Trabajos documentados, planillas firmadas y atención directa con el plomero responsable del trabajo.
              </p>
            </div>
          </div>

          <ul class="relative mt-8 grid grid-cols-2 gap-x-6 gap-y-3 text-[13px] text-slate-600">
            <li class="flex items-center gap-2"><Icon name="lucide:shield-check" class="w-4 h-4 text-brand-700 shrink-0" /> {licenseLabel()}</li>
            <li class="flex items-center gap-2"><Icon name="lucide:flame" class="w-4 h-4 text-brand-700 shrink-0" /> Gas aprobado</li>
            <li class="flex items-center gap-2"><Icon name="lucide:badge-check" class="w-4 h-4 text-brand-700 shrink-0" /> Garantía escrita</li>
            <li class="flex items-center gap-2"><Icon name="lucide:clock" class="w-4 h-4 text-brand-700 shrink-0" /> 24/7 urgencias</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="relative border-t border-slate-200">
    <div class="container-x">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-slate-200 border-x border-slate-200">
        {stats.map((s) => (
          <div class="hero-stat px-6 sm:px-8 py-10 sm:py-14 flex items-start justify-between gap-6 hover:bg-slate-50/70 transition-colors group">
            <div>
              <p class="display-md text-ink ticker tabular-nums min-w-[3ch]" data-counter={s.counter}>
                {s.n}
              </p>
              <p class="mt-2 text-sm text-slate-500">{s.label}</p>
            </div>
            <Icon name={s.icon} class="w-5 h-5 text-slate-300 group-hover:text-brand-600 transition-colors mt-1" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
