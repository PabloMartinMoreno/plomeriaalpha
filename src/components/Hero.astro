---
import { Icon } from 'astro-icon/components';
import { site, waLink, telLink } from '../data/site';

const stats = [
  { k: '+10', v: 'años', sub: 'de oficio' },
  { k: '+2.400', v: 'trabajos', sub: 'resueltos' },
  { k: '<2hs', v: 'respuesta', sub: 'en urgencias' },
  { k: '4.9', v: '/5', sub: 'calificación' },
];
---
<section class="relative isolate overflow-hidden bg-white">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[120%] aspect-square max-w-[900px] opacity-40 orb"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/0 via-white/60 to-white"></div>
    <svg class="absolute inset-0 w-full h-full opacity-[0.04]" aria-hidden="true">
      <defs>
        <pattern id="grid" width="56" height="56" patternUnits="userSpaceOnUse">
          <path d="M 56 0 L 0 0 0 56" fill="none" stroke="currentColor" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
    </svg>
  </div>

  <div class="container-x pt-16 pb-20 sm:pt-24 sm:pb-28 lg:pt-32 lg:pb-36">
    <div class="max-w-4xl">
      <span class="eyebrow reveal">
        <span class="ring-dot"></span>
        Disponible ahora · Zona Norte GBA
      </span>

      <h1 class="reveal mt-8 display text-ink">
        Plomería de oficio,
        <span class="italic-display text-brand-700">sin vueltas</span>,
        <br class="hidden sm:block"/>
        en <span class="underline decoration-accent-500 decoration-4 underline-offset-8">Zona&nbsp;Norte</span>.
      </h1>

      <p class="reveal mt-8 max-w-2xl text-lg sm:text-xl text-slate-600 leading-relaxed">
        Soy <strong class="text-ink font-semibold">{site.owner.name}</strong>, plomero matriculado. Resuelvo
        urgencias, fugas, gas y termotanques con presupuesto sin cargo y trabajo con garantía escrita.
      </p>

      <div class="reveal mt-10 flex flex-wrap gap-3">
        <a href={waLink()} class="btn-whatsapp" target="_blank" rel="noopener">
          <Icon name="lucide:message-circle" class="w-5 h-5" />
          Pedir presupuesto
          <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
        </a>
        <a href={telLink} class="btn-outline">
          <Icon name="lucide:phone" class="w-4 h-4" />
          Llamar ahora
        </a>
      </div>

      <div class="reveal mt-14 flex items-center gap-3 text-sm text-slate-500">
        <div class="flex -space-x-2">
          {[0,1,2,3].map((i) => (
            <span class="inline-block h-8 w-8 rounded-full ring-2 ring-white bg-gradient-to-br from-brand-400 to-brand-700" style={`transform: rotate(${i*4}deg)`}></span>
          ))}
        </div>
        <span>Elegido por <strong class="text-ink">+500 familias</strong> en Vicente López, San Isidro y Tigre.</span>
      </div>
    </div>
  </div>

  <div class="relative border-t border-slate-200 bg-slate-50/50">
    <div class="container-x">
      <ul class="grid grid-cols-2 md:grid-cols-4 divide-x divide-slate-200 border-x border-slate-200">
        {stats.map((s) => (
          <li class="px-5 py-8 sm:py-10">
            <p class="flex items-baseline gap-1.5">
              <span class="display-sm !text-3xl sm:!text-5xl text-ink">{s.k}</span>
              <span class="text-sm font-medium text-slate-500">{s.v}</span>
            </p>
            <p class="mt-1 text-xs uppercase tracking-[0.14em] text-slate-500">{s.sub}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
