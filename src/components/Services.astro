---
import { Icon } from 'astro-icon/components';
import { waLink } from '../data/site';

const services = [
  { icon: 'lucide:zap', title: 'Urgencias 24/7', desc: 'Inundaciones, roturas y fugas fuera de horario. Llegamos en menos de 2 horas.', big: true, accent: true, tag: 'Respuesta inmediata' },
  { icon: 'lucide:droplets', title: 'Destapaciones', desc: 'Piletas, inodoros y cloacas obstruidas. Equipo profesional.' },
  { icon: 'lucide:waves', title: 'Pérdidas y filtraciones', desc: 'Detección sin romper y reparación de caños rotos.' },
  { icon: 'lucide:flame', title: 'Gas domiciliario', desc: 'Instalación, reparación y pruebas de hermeticidad. Matrícula vigente.', big: true, tag: 'Matriculado' },
  { icon: 'lucide:thermometer', title: 'Termotanques y calefones', desc: 'Instalación, service y recambio de piezas.' },
  { icon: 'lucide:bath', title: 'Baños y cocinas', desc: 'Griferías, rejillas, inodoros, bachas y desagües.' },
  { icon: 'lucide:house-plug', title: 'Obra y refacción', desc: 'Cañerías completas y coordinación con obra.' },
];
---
<section id="servicios" class="section bg-white">
  <div class="container-x">
    <div class="grid md:grid-cols-12 gap-8 mb-16 md:items-end">
      <div class="md:col-span-8 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Servicios</span>
          <span class="h-px flex-1 max-w-24 bg-slate-200"></span>
        </div>
        <h2 class="display-lg" data-split="words">
          Todo lo que puede
          <span class="italic-display text-brand-700">fallar</span>,
          lo reparamos.
        </h2>
      </div>
      <div class="md:col-span-4 reveal">
        <p class="text-lg text-slate-600 leading-relaxed">
          Trabajos residenciales y comerciales en Zona Norte. Presupuesto sin cargo y trabajo con garantía escrita.
        </p>
        <a href={waLink('Hola, necesito consultar por un servicio.')} class="mt-6 inline-flex items-center gap-2 text-ink font-semibold border-b-2 border-ink pb-0.5 hover:gap-3 transition-all" target="_blank" rel="noopener">
          Consultar ahora <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[minmax(240px,_auto)] gap-3 reveal-stagger">
      {services.map((s, i) => {
        const span = s.big ? 'sm:col-span-2 row-span-1 sm:min-h-[300px]' : '';
        const isAccent = s.accent;
        return (
          <article
            class={`card group relative overflow-hidden flex flex-col justify-between ${span} ${isAccent ? '!bg-ink !border-ink text-white hover:!border-ink' : ''}`}
            data-tilt
          >
            <div class={`flex items-start justify-between ${isAccent ? '' : ''}`}>
              <div class={`grid place-items-center w-14 h-14 rounded-2xl ${isAccent ? 'bg-accent-500 text-ink' : 'bg-slate-100 text-ink group-hover:bg-ink group-hover:text-white'} transition-all duration-500`}>
                <Icon name={s.icon} class="w-6 h-6" stroke-width="1.5" />
              </div>
              <span class={`font-mono text-[11px] tracking-wider ${isAccent ? 'text-white/40' : 'text-slate-300'}`}>
                / 0{i+1}
              </span>
            </div>
            <div class="mt-auto pt-8">
              {s.tag && (
                <span class={`inline-block text-[10px] uppercase tracking-[0.18em] font-semibold mb-3 ${isAccent ? 'text-accent-400' : 'text-brand-700'}`}>
                  {s.tag}
                </span>
              )}
              <h3 class={`display-sm ${isAccent ? 'text-white' : ''}`}>{s.title}</h3>
              <p class={`mt-3 text-[15px] leading-relaxed ${isAccent ? 'text-white/70' : 'text-slate-600'}`}>{s.desc}</p>
            </div>
            {s.big && (
              <div aria-hidden="true" class={`absolute -right-10 -bottom-10 text-[180px] font-display italic leading-none opacity-[0.04] ${isAccent ? 'text-white opacity-[0.08]' : 'text-ink'}`}>
                {String(i+1).padStart(2, '0')}
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>

</section>
