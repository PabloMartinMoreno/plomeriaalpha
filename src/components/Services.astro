---
import { Icon } from 'astro-icon/components';
import { waLink } from '../data/site';

const services = [
  { icon: 'lucide:zap', title: 'Urgencias 24/7', desc: 'Inundaciones, roturas y fugas. Llegamos el mismo día.', big: true, accent: true },
  { icon: 'lucide:droplets', title: 'Destapaciones', desc: 'Piletas, inodoros y cloacas obstruidas.' },
  { icon: 'lucide:waves', title: 'Pérdidas', desc: 'Detección sin romper y reparación de caños.' },
  { icon: 'lucide:flame', title: 'Gas domiciliario', desc: 'Instalación y pruebas de hermeticidad. Matrícula vigente.', big: true },
  { icon: 'lucide:thermometer', title: 'Termotanques', desc: 'Instalación, service y recambio de piezas.' },
  { icon: 'lucide:bath', title: 'Baños y cocinas', desc: 'Griferías, rejillas, inodoros y bachas.' },
  { icon: 'lucide:house', title: 'Obra y refacción', desc: 'Cañerías completas y montaje de sanitarios.' },
];
---
<section id="servicios" class="section bg-white">
  <div class="container-x">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div class="max-w-2xl reveal">
        <span class="eyebrow"><Icon name="lucide:wrench" class="w-3.5 h-3.5" />Servicios</span>
        <h2 class="display-sm mt-5">
          Todo lo que puede fallar,
          <span class="italic-display text-brand-700">lo reparamos</span>.
        </h2>
        <p class="mt-5 text-lg text-slate-600 max-w-xl">
          Trabajos residenciales y comerciales. Presupuesto sin cargo antes de arrancar.
        </p>
      </div>
      <a href={waLink('Hola Jonatan, necesito consultar por un servicio.')} class="btn-outline self-start" target="_blank" rel="noopener">
        Consultar ahora <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[minmax(200px,_auto)] gap-4">
      {services.map((s, i) => {
        const span = s.big ? 'sm:col-span-2' : '';
        const isAccent = s.accent;
        return (
          <article class={`reveal card gradient-border ${span} ${isAccent ? 'bg-ink !border-ink text-white hover:!border-ink' : ''} group`}>
            <div class="flex items-start justify-between">
              <div class={`grid place-items-center w-12 h-12 rounded-xl ${isAccent ? 'bg-white/10 text-white' : 'bg-brand-50 text-brand-700 group-hover:bg-brand-600 group-hover:text-white'} transition-colors duration-500`}>
                <Icon name={s.icon} class="w-5 h-5" />
              </div>
              <span class={`text-xs font-mono ${isAccent ? 'text-white/40' : 'text-slate-300'}`}>
                0{i+1}
              </span>
            </div>
            <h3 class={`mt-6 text-xl font-semibold ${isAccent ? 'text-white' : 'text-ink'}`}>{s.title}</h3>
            <p class={`mt-2 text-sm leading-relaxed ${isAccent ? 'text-white/70' : 'text-slate-600'}`}>{s.desc}</p>
            {s.big && (
              <div class={`mt-auto pt-6 flex items-center gap-2 text-sm font-medium ${isAccent ? 'text-accent-400' : 'text-brand-700'}`}>
                Consultar <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>
