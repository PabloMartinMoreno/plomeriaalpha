---
import { Icon } from 'astro-icon/components';
import { site, waLink, services, cta, priceHintLabel } from '../data/site';
---
<section id="servicios" class="section bg-white">
  <div class="container-x">
    <div class="grid md:grid-cols-12 gap-8 mb-16 md:items-center">
      <div class="md:col-span-8 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Servicios</span>
          <span class="h-px flex-1 max-w-24 bg-slate-200"></span>
        </div>
        <h2 class="display-lg" data-split="words">
          Todo lo que puede
          <span class="italic-display text-brand-700">fallar</span>,
          lo reparamos.
        </h2>
      </div>
      <div class="md:col-span-4 reveal">
        <p class="text-lg text-slate-600 leading-relaxed">
          Trabajos residenciales y comerciales en Zona Norte. Presupuesto sin cargo y trabajo con garantía escrita.
        </p>
        <a href={waLink({ source: 'services-intro' })} class="mt-6 inline-flex items-center gap-2 text-ink font-semibold border-b-2 border-ink pb-0.5 hover:gap-3 transition-all" target="_blank" rel="noopener" data-track="cta:services-intro:whatsapp">
          {cta.primary} <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[minmax(240px,_auto)] gap-3 reveal-stagger">
      {services.map((s, i) => {
        const span = s.big ? 'sm:col-span-2 row-span-1 sm:min-h-[300px]' : '';
        const isAccent = (s as any).accent;
        return (
          <a
            href={`/servicios/${s.slug}`}
            class={`card group relative overflow-hidden flex flex-col ${span} ${isAccent ? '!bg-ink !border-ink text-white hover:!border-ink' : ''}`}
            data-tilt
          >
            <div class="flex items-start justify-between">
              <div class={`grid place-items-center w-14 h-14 rounded-2xl ${isAccent ? 'bg-accent-500 text-ink' : 'bg-slate-100 text-ink group-hover:bg-ink group-hover:text-white'} transition-all duration-500`}>
                <Icon name={s.icon} class="w-6 h-6" stroke-width="1.5" />
              </div>
              <span class={`font-mono text-[11px] tracking-wider ${isAccent ? 'text-white/40' : 'text-slate-300'}`}>
                / 0{i+1}
              </span>
            </div>

            <span class={`mt-8 block text-[10px] uppercase tracking-[0.18em] font-semibold min-h-[1.2em] ${isAccent ? 'text-accent-400' : 'text-brand-700'}`}>
              {(s as any).tag || ' '}
            </span>

            <h3 class={`mt-2 display-sm ${isAccent ? 'text-white' : ''}`}>{s.title}</h3>
            <p class={`mt-3 text-[15px] leading-relaxed ${isAccent ? 'text-white/70' : 'text-slate-600'}`}>{s.short}</p>

            <div class={`mt-4 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] ${isAccent ? 'text-white/60' : 'text-slate-500'}`}>
              <Icon name="lucide:tag" class="w-3 h-3" />
              {priceHintLabel(s.slug)}
            </div>

            <div class="mt-auto pt-6 flex items-center gap-4">
              <span class={`inline-flex items-center gap-1.5 text-[13px] font-semibold ${isAccent ? 'text-accent-400' : 'text-brand-700'} group-hover:gap-2.5 transition-all`}>
                Ver detalle <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
              </span>
              <span
                role="button"
                tabindex="0"
                data-wa-card
                data-wa-service={s.title}
                data-wa-source={`services-card-${s.slug}`}
                class={`inline-flex items-center gap-1.5 text-[12px] font-semibold px-3 py-1.5 rounded-full ${isAccent ? 'bg-white/10 text-white hover:bg-white/20' : 'bg-slate-100 text-ink hover:bg-ink hover:text-white'} transition cursor-pointer`}
              >
                <Icon name="lucide:message-circle" class="w-3 h-3" />
                Consultar
              </span>
            </div>

            {s.big && (
              <div aria-hidden="true" class={`absolute -right-10 -bottom-10 text-[180px] font-display italic leading-none opacity-[0.04] ${isAccent ? 'text-white opacity-[0.08]' : 'text-ink'}`}>
                {String(i+1).padStart(2, '0')}
              </div>
            )}
          </a>
        );
      })}
    </div>
  </div>

  <script is:inline define:vars={{ wa: site.contact.whatsapp }}>
    document.addEventListener('click', (e) => {
      const el = e.target.closest('[data-wa-card]');
      if (!el) return;
      e.preventDefault();
      e.stopPropagation();
      const service = el.dataset.waService || '';
      const source = el.dataset.waSource || 'services-card';
      const msg = `Hola, consulta desde la web:\n· Servicio: ${service}`;
      const url = `https://wa.me/${wa}?text=${encodeURIComponent(msg)}&utm_source=web&utm_content=${encodeURIComponent(source)}`;
      window.open(url, '_blank', 'noopener');
    });
  </script>
</section>
