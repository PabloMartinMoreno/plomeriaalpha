---
import { Icon } from 'astro-icon/components';
import { site, telLink, waLink } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="bg-slate-950 text-slate-400">
  <div class="container-x py-12 grid md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-2 text-white font-bold">
        <span class="grid place-items-center w-9 h-9 rounded-lg bg-brand-600">
          <Icon name="lucide:wrench" class="w-5 h-5" />
        </span>
        {site.shortName}
      </div>
      <p class="mt-4 text-sm leading-relaxed">
        Plomero matriculado en Zona Norte GBA. Urgencias, gas, pérdidas y reparaciones.
      </p>
    </div>

    <div>
      <h4 class="text-white font-semibold text-sm uppercase tracking-wider">Contacto</h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a href={telLink} class="hover:text-white flex items-center gap-2">
            <Icon name="lucide:phone" class="w-4 h-4" /> {site.contact.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={waLink()} target="_blank" rel="noopener" class="hover:text-white flex items-center gap-2">
            <Icon name="lucide:message-circle" class="w-4 h-4" /> WhatsApp
          </a>
        </li>
        <li>
          <a href={`mailto:${site.contact.email}`} class="hover:text-white flex items-center gap-2 break-all">
            <Icon name="lucide:mail" class="w-4 h-4" /> {site.contact.email}
          </a>
        </li>
        <li class="flex items-center gap-2">
          <Icon name="lucide:clock" class="w-4 h-4" /> {site.contact.hours}
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-semibold text-sm uppercase tracking-wider">Áreas</h4>
      <p class="mt-4 text-sm leading-relaxed">
        {site.address.areaServed.join(' · ')}
      </p>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="container-x py-6 text-xs flex flex-col sm:flex-row items-center justify-between gap-2">
      <p>© {year} {site.shortName}. Todos los derechos reservados.</p>
      <p>Sitio desarrollado con Astro.</p>
    </div>
  </div>
</footer>
