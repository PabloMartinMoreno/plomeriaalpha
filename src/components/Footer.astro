---
import { Icon } from 'astro-icon/components';
import { site, telLink, waLink, zones, services, licenseLabel } from '../data/site';

const year = new Date().getFullYear();
const footerServices = services.slice(0, 6);
---
<footer class="bg-white border-t border-slate-200 text-slate-600">
  <div class="container-x py-16">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <div class="flex items-center gap-2.5 text-ink font-semibold">
          <span class="grid place-items-center w-10 h-10 rounded-xl bg-ink text-white">
            <Icon name="lucide:droplet" class="w-5 h-5" />
          </span>
          <span class="flex flex-col leading-none">
            <span class="text-base">{site.shortName}</span>
            <span class="text-[10px] uppercase tracking-[0.18em] text-slate-500 mt-1">Zona Norte GBA</span>
          </span>
        </div>
        <p class="mt-5 text-sm leading-relaxed max-w-sm">
          Plomería matriculada en Zona Norte GBA. Urgencias, gas, pérdidas, termotanques y reparaciones con garantía escrita.
        </p>
        <div class="mt-6 flex gap-3">
          <a href={waLink()} target="_blank" rel="noopener" class="grid place-items-center w-10 h-10 rounded-xl border border-slate-200 hover:bg-ink hover:text-white hover:border-ink transition" aria-label="WhatsApp">
            <Icon name="lucide:message-circle" class="w-5 h-5" />
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener" class="grid place-items-center w-10 h-10 rounded-xl border border-slate-200 hover:bg-ink hover:text-white hover:border-ink transition" aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" />
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" class="grid place-items-center w-10 h-10 rounded-xl border border-slate-200 hover:bg-ink hover:text-white hover:border-ink transition" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-ink font-semibold text-sm">Servicios</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {footerServices.map((s) => (
            <li><a href={`/servicios/${s.slug}`} class="hover:text-ink transition">{s.title}</a></li>
          ))}
          <li><a href="/servicios" class="font-semibold text-ink hover:underline">Ver todos los servicios</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-ink font-semibold text-sm">Sitio</h4>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/" class="hover:text-ink transition">Inicio</a></li>
          <li><a href="/servicios" class="hover:text-ink transition">Servicios</a></li>
          <li><a href="/zonas" class="hover:text-ink transition">Zonas</a></li>
          <li><a href="/contacto" class="hover:text-ink transition">Contacto</a></li>
          <li><a href="/privacidad" class="hover:text-ink transition">Privacidad</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-ink font-semibold text-sm">Contacto</h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href={telLink} class="hover:text-ink flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4" /> {site.contact.phoneDisplay}</a></li>
          <li><a href={waLink()} target="_blank" rel="noopener" class="hover:text-ink flex items-center gap-2"><Icon name="lucide:message-circle" class="w-4 h-4" /> WhatsApp</a></li>
          <li><a href={`mailto:${site.contact.email}`} class="hover:text-ink flex items-center gap-2 break-all"><Icon name="lucide:mail" class="w-4 h-4" /> {site.contact.email}</a></li>
          <li class="flex items-center gap-2"><Icon name="lucide:clock" class="w-4 h-4" /> {site.contact.hours}</li>
        </ul>
        <p class="mt-6 text-[11px] uppercase tracking-[0.18em] text-slate-500">{licenseLabel()}</p>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-200">
      <h4 class="text-ink font-semibold text-sm">Áreas de cobertura</h4>
      <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-1.5 text-sm leading-relaxed">
        {zones.map((z) => (
          <li><a href={`/zonas/${z.slug}`} class="hover:text-ink transition">{z.name}</a></li>
        ))}
        <li><a href="/zonas" class="font-semibold text-ink hover:underline">Ver todas</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="container-x py-5 text-xs flex flex-col sm:flex-row items-center justify-between gap-2 text-slate-500">
      <p>© {year} {site.shortName}. Todos los derechos reservados.</p>
      <p class="flex items-center gap-2">
        <span>Hecho con</span>
        <Icon name="lucide:heart" class="w-3.5 h-3.5 text-accent-500 fill-current" />
        <span>en Buenos Aires</span>
      </p>
    </div>
  </div>
</footer>
