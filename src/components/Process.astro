---
import { Icon } from 'astro-icon/components';

const steps = [
  { n: '01', icon: 'lucide:message-circle', title: 'Escribís', desc: 'Contanos el problema por WhatsApp. Si podés, mandanos una foto o video.' },
  { n: '02', icon: 'lucide:clipboard-check', title: 'Coordinamos', desc: 'Te damos estimación aproximada o coordinamos visita diagnóstica sin cargo.' },
  { n: '03', icon: 'lucide:hard-hat', title: 'Resolvemos', desc: 'Llegamos puntual, trabajamos limpio y te explicamos cada paso del proceso.' },
  { n: '04', icon: 'lucide:shield-check', title: 'Garantizamos', desc: 'Entregamos con comprobante y garantía escrita sobre el trabajo hecho.' },
];
---
<section id="proceso" class="section relative overflow-hidden text-white mesh-dark grain">
  <div class="container-x relative z-10">
    <div class="grid lg:grid-cols-12 gap-10 mb-20">
      <div class="lg:col-span-7 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/50">— Cómo trabajamos</span>
          <span class="h-px flex-1 max-w-24 bg-white/20"></span>
        </div>
        <h2 class="display-lg text-white">
          Cuatro pasos,
          <span class="italic-display text-accent-400">cero sorpresas</span>.
        </h2>
      </div>
      <div class="lg:col-span-5 reveal flex items-end">
        <p class="text-lg text-white/70 leading-relaxed">
          Una forma de trabajar pensada para que sepas exactamente qué va a pasar antes, durante y después.
          Nada escondido, nada improvisado.
        </p>
      </div>
    </div>

    <ol class="grid md:grid-cols-2 lg:grid-cols-4 gap-[1px] bg-white/10 border border-white/10 rounded-3xl overflow-hidden reveal-stagger">
      {steps.map((s) => (
        <li class="bg-ink p-8 sm:p-10 flex flex-col min-h-[280px] hover:bg-white/[0.03] transition-colors">
          <div class="flex items-start justify-between">
            <span class="grid place-items-center w-12 h-12 rounded-xl bg-white/10 text-white">
              <Icon name={s.icon} class="w-5 h-5" stroke-width="1.5" />
            </span>
            <span class="font-mono text-sm text-white/40">{s.n}</span>
          </div>
          <div class="mt-auto pt-12">
            <h3 class="text-2xl font-display text-white">{s.title}</h3>
            <p class="mt-3 text-sm text-white/60 leading-relaxed">{s.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
