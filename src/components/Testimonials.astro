---
import { Icon } from 'astro-icon/components';

const items = [
  { name: 'Laura M.', area: 'Martínez', text: 'Tenía una pérdida en el baño hacía semanas. Vino el mismo día, la detectó sin romper y la resolvió en dos horas. Impecable.', rating: 5 },
  { name: 'Diego P.', area: 'Vicente López', text: 'Nos cambió el termotanque y actualizó las cañerías viejas. Trabajo prolijo, presupuesto claro y cumplió los tiempos pactados.', rating: 5 },
  { name: 'Familia Giménez', area: 'San Isidro', text: 'Urgencia un sábado a la noche: cloaca tapada. Vino en menos de una hora y lo resolvió ahí mismo. De diez.', rating: 5 },
  { name: 'Marcos R.', area: 'Tigre', text: 'Instalación de gas aprobada en tiempo récord. Los pibes de Metrogas no pusieron una objeción. Recomendadísimo.', rating: 5 },
];
---
<section class="section bg-white overflow-hidden">
  <div class="container-x mb-14">
    <div class="max-w-3xl reveal">
      <span class="eyebrow"><Icon name="lucide:quote" class="w-3.5 h-3.5" />Clientes</span>
      <h2 class="display-sm mt-5">
        Más de 500 familias
        <span class="italic-display text-brand-700">nos eligen</span>.
      </h2>
    </div>
  </div>

  <div class="relative">
    <div class="flex gap-5 marquee-track w-max" style="animation-direction: alternate;">
      {[...items, ...items].map((t) => (
        <figure class="w-[360px] sm:w-[420px] shrink-0 rounded-2xl border border-slate-200 bg-white p-7 hover:border-ink transition-all duration-500">
          <div class="flex items-center gap-0.5 text-accent-500 mb-4" aria-label={`${t.rating} de 5 estrellas`}>
            {Array.from({ length: t.rating }).map(() => (
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
            ))}
          </div>
          <blockquote class="text-ink text-lg leading-relaxed font-display">&ldquo;{t.text}&rdquo;</blockquote>
          <figcaption class="mt-6 pt-5 border-t border-slate-100 flex items-center gap-3">
            <span class="grid place-items-center w-10 h-10 rounded-full bg-gradient-to-br from-brand-400 to-brand-700 text-white font-semibold text-sm">
              {t.name[0]}
            </span>
            <div>
              <p class="font-semibold text-ink text-sm">{t.name}</p>
              <p class="text-xs text-slate-500">{t.area}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-white to-transparent"></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-white to-transparent"></div>
  </div>
</section>
