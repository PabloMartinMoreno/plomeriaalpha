---
import { Icon } from 'astro-icon/components';

const items = [
  {
    name: 'Laura M.',
    area: 'Martínez',
    text: 'Tenía una pérdida en el baño hacía semanas. Jonatan vino el mismo día, detectó el problema sin romper y lo resolvió en dos horas. Impecable.',
    rating: 5,
  },
  {
    name: 'Diego P.',
    area: 'Vicente López',
    text: 'Nos cambió el termotanque y actualizó las cañerías viejas. Trabajo prolijo, presupuesto claro y cumplió los tiempos que había dicho.',
    rating: 5,
  },
  {
    name: 'Familia Giménez',
    area: 'San Isidro',
    text: 'Urgencia un sábado a la noche: cloaca tapada. Vino en menos de una hora. De diez.',
    rating: 5,
  },
];
---
<section class="section bg-slate-50">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="chip bg-white">
        <Icon name="lucide:quote" class="w-3.5 h-3.5 text-brand-600" />
        Clientes
      </span>
      <h2 class="section-title mt-3">Lo que dicen de nosotros.</h2>
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-5">
      {items.map((t) => (
        <blockquote class="card flex flex-col gap-4">
          <div class="flex gap-0.5 text-amber-500" aria-label={`${t.rating} de 5 estrellas`}>
            {Array.from({ length: t.rating }).map(() => (
              <Icon name="lucide:star" class="w-4 h-4 fill-current" />
            ))}
          </div>
          <p class="text-slate-700 leading-relaxed">&ldquo;{t.text}&rdquo;</p>
          <footer class="mt-auto pt-4 border-t border-slate-100">
            <p class="font-semibold text-slate-900 text-sm">{t.name}</p>
            <p class="text-xs text-slate-500">{t.area}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
