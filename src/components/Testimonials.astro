---
import { Icon } from 'astro-icon/components';

const items = [
  { name: 'Laura M.', area: 'Martínez', text: 'Tenía una pérdida en el baño hacía semanas. Vino el mismo día, la detectó sin romper y la resolvió en dos horas. Impecable.', rating: 5 },
  { name: 'Diego P.', area: 'Vicente López', text: 'Nos cambió el termotanque y actualizó cañerías viejas. Trabajo prolijo, presupuesto claro y cumplió los tiempos pactados.', rating: 5 },
  { name: 'Familia Giménez', area: 'San Isidro', text: 'Urgencia un sábado a la noche: cloaca tapada. Vino en menos de una hora y lo resolvió ahí mismo. De diez.', rating: 5 },
  { name: 'Marcos R.', area: 'Tigre', text: 'Instalación de gas aprobada en tiempo récord. Los inspectores de la distribuidora no pusieron una objeción.', rating: 5 },
  { name: 'Carla V.', area: 'Beccar', text: 'Presupuesto por escrito, trabajo puntual y me mandó hasta las fotos del "antes y después". Profesional.', rating: 5 },
];
---
<section class="section-tight bg-white overflow-hidden">
  <div class="container-x mb-16">
    <div class="grid lg:grid-cols-12 gap-10 items-end">
      <div class="lg:col-span-8 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Clientes</span>
          <span class="h-px flex-1 max-w-24 bg-slate-200"></span>
        </div>
        <h2 class="display-lg">
          Más de 500 familias
          <span class="italic-display text-brand-700">nos eligen</span>.
        </h2>
      </div>
      <div class="lg:col-span-4 reveal">
        <div class="flex items-center gap-3">
          <div class="flex gap-0.5 text-accent-500">
            {Array.from({ length: 5 }).map(() => <Icon name="lucide:star" class="w-5 h-5 fill-current" />)}
          </div>
          <p class="text-sm text-slate-600"><strong class="text-ink">4.9/5</strong> · +200 reseñas</p>
        </div>
      </div>
    </div>
  </div>

  <div class="relative">
    <div class="flex gap-5 marquee-track w-max">
      {[...items, ...items].map((t) => (
        <figure class="w-[380px] sm:w-[460px] shrink-0 rounded-3xl border border-slate-200 bg-white p-8 hover:border-ink transition-all duration-500 flex flex-col">
          <Icon name="lucide:quote" class="w-8 h-8 text-slate-200" />
          <blockquote class="mt-6 text-ink text-xl leading-[1.5] font-display font-light">
            &ldquo;{t.text}&rdquo;
          </blockquote>
          <figcaption class="mt-auto pt-8 flex items-center gap-4">
            <span class="grid place-items-center w-11 h-11 rounded-full bg-ink text-white font-display italic text-base">
              {t.name[0]}
            </span>
            <div class="flex-1">
              <p class="font-semibold text-ink text-[15px]">{t.name}</p>
              <p class="text-xs uppercase tracking-[0.14em] text-slate-500 mt-0.5">{t.area}</p>
            </div>
            <div class="flex gap-0.5 text-accent-500">
              {Array.from({ length: t.rating }).map(() => <Icon name="lucide:star" class="w-3.5 h-3.5 fill-current" />)}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-white to-transparent z-10"></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-white to-transparent z-10"></div>
  </div>
</section>
