---
import { Icon } from 'astro-icon/components';
import { waLink } from '../data/site';

type Shot = {
  beforeSrc: string;
  afterSrc: string;
  alt: string;
  caption: string;
  area?: string;
};

const shots: Shot[] = [];
---
<section id="trabajos" class="section bg-white relative">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-10 mb-16">
      <div class="lg:col-span-7 reveal">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Trabajos</span>
          <span class="h-px flex-1 max-w-24 bg-slate-200"></span>
        </div>
        <h2 class="display-lg" data-split="words">
          Antes
          <span class="italic-display text-brand-700">y después</span>.
        </h2>
      </div>
      <div class="lg:col-span-5 reveal flex items-end">
        <p class="text-lg text-slate-600 leading-relaxed">
          Una selección de trabajos resueltos en casas, PH y comercios de Zona Norte. Pedí la galería completa por WhatsApp.
        </p>
      </div>
    </div>

    {shots.length === 0 ? (
      <div class="reveal rounded-[32px] border border-dashed border-slate-300 bg-slate-50/50 p-10 sm:p-16 text-center">
        <span class="grid place-items-center w-14 h-14 rounded-2xl bg-white border border-slate-200 text-slate-400 mx-auto">
          <Icon name="lucide:image" class="w-6 h-6" stroke-width="1.5" />
        </span>
        <h3 class="mt-6 display-sm text-ink !font-medium">Galería en preparación</h3>
        <p class="mt-3 text-slate-600 max-w-md mx-auto leading-relaxed">
          Estamos documentando los últimos trabajos. Si querés ver fotos específicas de un tipo de arreglo, pedilas directo por WhatsApp y te las mandamos.
        </p>
        <a href={waLink('Hola, ¿me pueden mandar fotos de trabajos similares al que necesito?')} class="mt-8 btn-dark btn-arrow inline-flex" target="_blank" rel="noopener" data-magnetic="0.25">
          <Icon name="lucide:message-circle" class="w-4 h-4" />
          Pedir galería
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 reveal-stagger">
        {shots.map((shot) => (
          <figure class="group rounded-3xl overflow-hidden border border-slate-200 bg-white hover:border-ink transition-all">
            <div class="relative aspect-[4/3] bg-slate-100 overflow-hidden grid grid-cols-2 gap-px">
              <img src={shot.beforeSrc} alt={`Antes — ${shot.alt}`} loading="lazy" decoding="async" class="w-full h-full object-cover" />
              <img src={shot.afterSrc} alt={`Después — ${shot.alt}`} loading="lazy" decoding="async" class="w-full h-full object-cover" />
              <span class="absolute left-3 top-3 text-[10px] uppercase tracking-[0.18em] bg-white/90 text-ink px-2 py-1 rounded-full">Antes</span>
              <span class="absolute right-3 top-3 text-[10px] uppercase tracking-[0.18em] bg-ink text-white px-2 py-1 rounded-full">Después</span>
            </div>
            <figcaption class="p-5">
              <p class="text-[15px] text-ink leading-snug">{shot.caption}</p>
              {shot.area && <p class="text-xs text-slate-500 mt-1 uppercase tracking-[0.14em]">{shot.area}</p>}
            </figcaption>
          </figure>
        ))}
      </div>
    )}
  </div>
</section>
