---
import '../styles/global.css';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/fraunces/wght-italic.css';
import '@fontsource-variable/inter';
import { SEO } from 'astro-seo';
import { site, zones, services, licenseLabel } from '../data/site';
import MobileStickyBar from '../components/MobileStickyBar.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = site.name,
  description = site.description,
  canonical = Astro.url.href,
  image = '/og-cover.jpg',
  noindex = false,
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} · ${site.shortName}`;

const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const plausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SRC || 'https://plausible.io/js/script.js';
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: site.contact.phone,
  email: site.contact.email,
  image: new URL(image, site.url).toString(),
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  areaServed: zones.map((z) => ({ '@type': 'City', name: z.name })),
  geo: site.address.geo
    ? { '@type': 'GeoCoordinates', latitude: site.address.geo.lat, longitude: site.address.geo.lng }
    : undefined,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: site.contact.openingHours.weekdays.opens,
      closes: site.contact.openingHours.weekdays.closes,
    },
  ],
  ...(site.license.active && site.license.number
    ? { hasCredential: { '@type': 'EducationalOccupationalCredential', name: licenseLabel() } }
    : {}),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de plomería',
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: s.title,
        description: s.meta,
        url: `${site.url}/servicios/${s.slug}`,
      },
    })),
  },
  sameAs: [site.social.instagram, site.social.facebook].filter(Boolean),
};

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.shortName,
  legalName: site.name,
  url: site.url,
  logo: new URL('/favicon.svg', site.url).toString(),
  image: new URL(image, site.url).toString(),
  email: site.contact.email,
  telephone: site.contact.phone,
  founder: { '@type': 'Person', name: site.owner.name, jobTitle: site.owner.role },
  sameAs: [site.social.instagram, site.social.facebook].filter(Boolean),
};
---
<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b1220" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'website',
          image: new URL(image, site.url).toString(),
          url: canonical,
        },
        optional: { description, siteName: site.shortName, locale: site.locale },
      }}
      twitter={{ card: 'summary_large_image', title: fullTitle, description }}
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    {plausibleDomain && (
      <>
        <script defer data-domain={plausibleDomain} src={plausibleSrc}></script>
        <script is:inline set:html={`window.plausible=window.plausible||function(){(window.plausible.q=window.plausible.q||[]).push(arguments)}`} />
      </>
    )}

    {clarityId && (
      <script is:inline set:html={`
        (function(){
          var loadClarity = function(){
            (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${clarityId}");
          };
          try {
            var c = localStorage.getItem('cookie-consent');
            if (c === 'accepted') loadClarity();
            window.__loadClarity = loadClarity;
          } catch(e) { /* storage blocked */ }
        })();
      `} />
    )}
  </head>
  <body class="overflow-x-hidden pb-16 md:pb-0">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:px-3 focus:py-2 focus:rounded focus:shadow">
      Saltar al contenido
    </a>
    <slot />
    <MobileStickyBar />
    <CookieBanner />

    <script>
      import '../scripts/motion';
    </script>
  </body>
</html>
