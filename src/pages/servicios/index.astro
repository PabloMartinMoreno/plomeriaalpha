---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { services, site, waLink, cta, priceHintLabel } from '../../data/site';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${site.url}/servicios` },
  ],
};
---
<BaseLayout
  title="Servicios de plomería"
  description="Todos los servicios de Plomería Alpha en Zona Norte GBA: urgencias 24/7, destapes, gas matriculado, termotanques, pérdidas y reformas."
>
  <Header />
  <main id="main">
    <article class="relative isolate bg-white">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 opacity-60">
        <div class="absolute inset-0 mesh-bg"></div>
      </div>
      <div class="container-x pt-28 sm:pt-36 pb-16">
        <nav class="text-xs uppercase tracking-[0.18em] text-slate-500 flex items-center gap-2 mb-10" aria-label="Migas de pan">
          <a href="/" class="hover:text-ink transition">Inicio</a>
          <span class="text-slate-300">/</span>
          <span class="text-ink">Servicios</span>
        </nav>
        <div class="max-w-3xl">
          <span class="eyebrow">
            <Icon name="lucide:wrench" class="w-3.5 h-3.5" />
            Catálogo de servicios
          </span>
          <h1 class="mt-6 display-xl text-ink !leading-[0.95]" data-split="words">
            Todo lo que <span class="italic-display text-brand-700">reparamos</span>.
          </h1>
          <p class="mt-8 text-xl text-slate-600 leading-relaxed font-light">
            Trabajos residenciales y comerciales en Zona Norte GBA con presupuesto sin cargo y garantía escrita.
          </p>
        </div>
      </div>
    </article>

    <section class="section-tight bg-white border-t border-slate-200">
      <div class="container-x">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 auto-rows-[minmax(240px,_auto)]">
          {services.map((s, i) => {
            const isAccent = (s as any).accent;
            const span = (s as any).big ? 'sm:col-span-2 sm:min-h-[300px]' : '';
            return (
              <a
                href={`/servicios/${s.slug}`}
                class={`card group relative overflow-hidden flex flex-col ${span} ${isAccent ? '!bg-ink !border-ink text-white hover:!border-ink' : ''}`}
              >
                <div class="flex items-start justify-between">
                  <span class={`grid place-items-center w-14 h-14 rounded-2xl ${isAccent ? 'bg-accent-500 text-ink' : 'bg-slate-100 text-ink group-hover:bg-ink group-hover:text-white'} transition-all`}>
                    <Icon name={s.icon} class="w-6 h-6" stroke-width="1.5" />
                  </span>
                  <span class={`font-mono text-[11px] ${isAccent ? 'text-white/50' : 'text-slate-400'}`}>/ 0{i+1}</span>
                </div>

                <span class={`mt-8 block text-[10px] uppercase tracking-[0.18em] font-semibold min-h-[1.2em] ${isAccent ? 'text-accent-400' : 'text-brand-700'}`}>
                  {(s as any).tag || ' '}
                </span>

                <h2 class={`mt-2 display-sm ${isAccent ? 'text-white' : ''}`}>{s.title}</h2>
                <p class={`mt-3 text-[15px] leading-relaxed ${isAccent ? 'text-white/70' : 'text-slate-600'}`}>{s.short}</p>

                <div class={`mt-4 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] ${isAccent ? 'text-white/60' : 'text-slate-500'}`}>
                  <Icon name="lucide:tag" class="w-3 h-3" />
                  {priceHintLabel(s.slug)}
                </div>

                <span class={`mt-auto pt-6 inline-flex items-center gap-1.5 text-[13px] font-semibold ${isAccent ? 'text-accent-400' : 'text-brand-700'} group-hover:gap-2.5 transition-all`}>
                  Ver detalle <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="section-tight bg-slate-50 border-t border-slate-200">
      <div class="container-x text-center">
        <h2 class="display-lg text-ink">¿No encontrás tu caso?</h2>
        <p class="mt-6 text-lg text-slate-600 max-w-xl mx-auto">
          Escribinos y te decimos si es algo que hacemos. Sin compromiso.
        </p>
        <a href={waLink({ source: 'servicios-index' })} class="btn-whatsapp btn-arrow mt-8 inline-flex" target="_blank" rel="noopener" data-track="cta:servicios-index:whatsapp">
          <Icon name="lucide:message-circle" class="w-[18px] h-[18px]" />
          {cta.primary}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloat />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
</BaseLayout>
