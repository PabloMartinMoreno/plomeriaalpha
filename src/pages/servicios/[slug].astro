---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import ServiceWizardMini from '../../components/ServiceWizardMini.astro';
import { services, zones, site, waLink, telLink, cta, serviceFaqs } from '../../data/site';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const otherServices = services.filter((s) => s.slug !== service.slug).slice(0, 4);
const faqs = serviceFaqs[service.slug] ?? [];

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.title} — ${site.shortName}`,
  description: service.meta,
  provider: { '@type': 'Plumber', name: site.shortName, url: site.url },
  areaServed: zones.map((z) => ({ '@type': 'City', name: z.name })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${site.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: service.title, item: `${site.url}/servicios/${service.slug}` },
  ],
};
---
<BaseLayout title={`${service.title} en Zona Norte`} description={service.meta}>
  <Header />
  <main id="main">
    <article class="relative isolate bg-white">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute inset-0 mesh-bg opacity-70"></div>
      </div>

      <div class="container-x pt-28 sm:pt-36 pb-20">
        <nav class="text-xs uppercase tracking-[0.18em] text-slate-500 flex items-center gap-2 mb-10" aria-label="Migas de pan">
          <a href="/" class="hover:text-ink transition">Inicio</a>
          <span class="text-slate-300">/</span>
          <a href="/#servicios" class="hover:text-ink transition">Servicios</a>
          <span class="text-slate-300">/</span>
          <span class="text-ink">{service.title}</span>
        </nav>

        <div class="grid lg:grid-cols-12 gap-16 items-start">
          <div class="lg:col-span-7">
            <span class="grid place-items-center w-16 h-16 rounded-2xl bg-ink text-white mb-8">
              <Icon name={service.icon} class="w-7 h-7" stroke-width="1.5" />
            </span>
            <h1 class="display-xl text-ink !leading-[0.95]" data-split="words">{service.title}</h1>
            <p class="mt-8 text-xl text-slate-600 leading-relaxed max-w-2xl font-light">
              {service.longDesc}
            </p>

            <div class="mt-12 grid sm:grid-cols-2 gap-4 max-w-2xl">
              {service.bullets.map((b) => (
                <div class="flex items-start gap-3 p-5 rounded-2xl border border-slate-200 bg-white">
                  <Icon name="lucide:check" class="w-4 h-4 text-brand-700 mt-1 shrink-0" />
                  <p class="text-[15px] text-slate-700 leading-snug">{b}</p>
                </div>
              ))}
            </div>

            <div class="mt-12 flex flex-wrap gap-3">
              <a href={waLink({ service: service.title, source: `servicio-${service.slug}` })} class="btn-whatsapp btn-arrow" target="_blank" rel="noopener" data-magnetic="0.3" data-track={`cta:servicio-${service.slug}:whatsapp`}>
                <Icon name="lucide:message-circle" class="w-[18px] h-[18px]" />
                {cta.primary}
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
              <a href={`/contacto?servicio=${service.slug}`} class="btn-outline" data-magnetic="0.25" data-track={`cta:servicio-${service.slug}:form`}>
                <Icon name="lucide:calendar-check" class="w-4 h-4" />
                {cta.schedule}
              </a>
              <a href={telLink} class="btn-ghost" data-track={`cta:servicio-${service.slug}:phone`}>
                <Icon name="lucide:phone" class="w-4 h-4" />
                {site.contact.phoneDisplay}
              </a>
            </div>
          </div>

          <aside class="lg:col-span-5 lg:pl-6 lg:sticky lg:top-28">
            <div class="rounded-3xl border border-slate-200 bg-white p-8">
              <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">Cobertura</p>
              <h2 class="mt-2 text-xl font-display text-ink">Atendemos en toda Zona Norte</h2>
              <ul class="mt-5 grid grid-cols-2 gap-1.5">
                {zones.slice(0, 10).map((z) => (
                  <li>
                    <a href={`/zonas/${z.slug}`} class="flex items-center gap-2 text-sm text-slate-600 hover:text-ink transition py-1">
                      <Icon name="lucide:map-pin" class="w-3.5 h-3.5 text-brand-600" />
                      {z.name}
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/#zonas" class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-ink border-b border-ink pb-0.5 hover:gap-2.5 transition-all">
                Ver todas las zonas <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
              </a>
            </div>
          </aside>
        </div>
      </div>
    </article>

    <section class="section-tight bg-slate-50 border-t border-slate-200">
      <div class="container-x">
        <div class="flex items-end justify-between mb-10">
          <h2 class="display-sm text-ink">Otros servicios</h2>
          <a href="/#servicios" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-ink border-b border-ink pb-0.5 hover:gap-2.5 transition-all">
            Ver todos <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {otherServices.map((s) => (
            <a href={`/servicios/${s.slug}`} class="card group block">
              <Icon name={s.icon} class="w-7 h-7 text-brand-700" stroke-width="1.5" />
              <h3 class="mt-8 text-lg font-display text-ink">{s.title}</h3>
              <p class="mt-2 text-sm text-slate-600 line-clamp-2">{s.short}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-[12px] font-semibold text-brand-700 group-hover:gap-2 transition-all">
                Ver <Icon name="lucide:arrow-up-right" class="w-3 h-3" />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <ServiceWizardMini service={{ slug: service.slug, title: service.title }} />

    {faqs.length > 0 && (
      <section class="section-tight bg-slate-50 border-t border-slate-200">
        <div class="container-x">
          <div class="grid md:grid-cols-12 gap-10 mb-10">
            <div class="md:col-span-6">
              <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500">— Preguntas sobre {service.title.toLowerCase()}</span>
              <h2 class="mt-4 display-lg">Dudas <span class="italic-display text-brand-700">puntuales</span>.</h2>
            </div>
            <div class="md:col-span-6 flex items-center">
              <p class="text-lg text-slate-600 leading-relaxed">
                Las consultas más frecuentes sobre este servicio. Si la tuya no está, escribinos por WhatsApp.
              </p>
            </div>
          </div>
          <div class="space-y-2">
            {faqs.map((item, i) => (
              <details class="reveal group rounded-2xl bg-white border border-slate-200 open:border-ink open:shadow-xl open:shadow-ink/5 transition-all duration-500 overflow-hidden">
                <summary class="flex cursor-pointer items-center justify-between gap-6 list-none px-7 py-6">
                  <div class="flex items-center gap-6">
                    <span class="font-mono text-xs text-slate-500 group-open:text-brand-600 transition-colors">{String(i+1).padStart(2,'0')}</span>
                    <h3 class="text-lg sm:text-xl font-display text-ink">{item.q}</h3>
                  </div>
                  <span class="shrink-0 relative w-5 h-5">
                    <span class="absolute inset-x-0 top-1/2 h-[2px] -translate-y-1/2 bg-ink"></span>
                    <span class="absolute inset-y-0 left-1/2 w-[2px] -translate-x-1/2 bg-ink transition-transform duration-500 group-open:rotate-90 group-open:scale-0"></span>
                  </span>
                </summary>
                <div class="px-7 pb-7 pl-[5rem]">
                  <p class="text-slate-600 leading-relaxed text-[15px]">{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
  <WhatsAppFloat />

  <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
</BaseLayout>
