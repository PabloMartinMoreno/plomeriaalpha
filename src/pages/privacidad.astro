---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

const updated = '2026-04-21';
---
<BaseLayout title="Política de privacidad" description={`Política de privacidad de ${site.shortName}.`} noindex>
  <Header />
  <main id="main">
    <article class="section bg-white">
      <div class="container-narrow prose-slate">
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Actualizado {updated}</p>
        <h1 class="mt-4 display-lg">Política de privacidad</h1>

        <div class="mt-10 space-y-8 text-slate-700 leading-relaxed">
          <section>
            <h2 class="display-sm text-ink !font-medium">Responsable</h2>
            <p class="mt-3">
              {site.shortName} ({site.owner.name}) es responsable del tratamiento de los datos personales que nos aportás
              al contactarnos por el formulario del sitio, WhatsApp, teléfono o correo.
            </p>
          </section>

          <section>
            <h2 class="display-sm text-ink !font-medium">Datos que recolectamos</h2>
            <ul class="mt-3 list-disc pl-6 space-y-2">
              <li>Datos de contacto que nos brindás voluntariamente: nombre, teléfono, zona y mensaje.</li>
              <li>Fotos o videos que compartas por WhatsApp para diagnosticar el trabajo.</li>
              <li>Datos técnicos básicos de navegación (no usamos cookies de terceros ni tracking publicitario).</li>
            </ul>
          </section>

          <section>
            <h2 class="display-sm text-ink !font-medium">Finalidad</h2>
            <p class="mt-3">
              Usamos tus datos únicamente para responder consultas, coordinar visitas y emitir presupuestos o facturas.
              No vendemos, cedemos ni compartimos tus datos con terceros, salvo obligación legal.
            </p>
          </section>

          <section>
            <h2 class="display-sm text-ink !font-medium">Conservación</h2>
            <p class="mt-3">
              Conservamos tus datos el tiempo necesario para la finalidad indicada y para cumplir con obligaciones
              contables y fiscales (5 años desde la última operación).
            </p>
          </section>

          <section>
            <h2 class="display-sm text-ink !font-medium">Tus derechos</h2>
            <p class="mt-3">
              Podés solicitar acceso, rectificación o supresión de tus datos escribiendo a
              <a class="underline hover:text-ink" href={`mailto:${site.contact.email}`}>{site.contact.email}</a>.
              También podés consultar ante la Agencia de Acceso a la Información Pública (www.argentina.gob.ar/aaip).
            </p>
          </section>

          <section>
            <h2 class="display-sm text-ink !font-medium">Seguridad</h2>
            <p class="mt-3">
              Guardamos tus datos en sistemas con medidas razonables de seguridad. Limitamos el acceso a quienes los
              necesitan para atender tu consulta.
            </p>
          </section>
        </div>

        <a href="/" class="mt-16 inline-block text-sm font-semibold text-ink border-b border-ink pb-0.5 hover:opacity-70 transition">
          ← Volver al inicio
        </a>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
