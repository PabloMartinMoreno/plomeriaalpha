---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Signature from '../components/Signature.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import WhyUs from '../components/WhyUs.astro';
import Zones from '../components/Zones.astro';
import Gallery from '../components/Gallery.astro';
import QuickWizard from '../components/QuickWizard.astro';
import AfterContact from '../components/AfterContact.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import BigCTA from '../components/BigCTA.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---
<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <TrustStrip />
    <Services />
    <Signature />
    <Process />
    <AfterContact />
    <WhyUs />
    <Zones />
    <Gallery />
    <QuickWizard />
    <Testimonials />
    <FAQ />
    <BigCTA />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
